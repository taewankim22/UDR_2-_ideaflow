generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  AI
  EDU
  TRAVEL
  ENV
  HEALTH
  ETC
}

enum Provider {
  email
  kakao
  google
}

model User {
  id              String             @id @default(cuid())
  email           String             @unique
  username        String
  profileImageUrl String?
  pointsBalance   Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  authIdentities  AuthIdentity[]
  ideas           Idea[]
  pointLedger     PointTransaction[]
  unlocks         IdeaUnlock[]

  @@map("users")
}

model AuthIdentity {
  id             String   @id @default(cuid())
  userId         String
  provider       Provider
  providerUserId String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("auth_identities")
}

model Idea {
  id             String        @id @default(cuid())
  title          String
  oneLine        String
  category       Category
  coverImageUrl  String?
  problem        String
  solution       String
  likeCount      Int           @default(0)
  commentCount   Int           @default(0)
  unlockCost     Int           @default(3)
  authorId       String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  whiteboard     Whiteboard?
  aiEvaluation   AIEvaluation?
  unlocks        IdeaUnlock[]
  pointLedger    PointTransaction[]

  @@index([createdAt])
  @@index([category])
  @@map("ideas")
}

model Whiteboard {
  ideaId    String   @id
  nodes     Json
  updatedAt DateTime @updatedAt
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@map("whiteboards")
}

model AIEvaluation {
  id           String   @id @default(cuid())
  ideaId       String   @unique
  overallScore Int
  scores       Json
  summary      String
  suggestions  Json
  createdAt    DateTime @default(now())
  idea         Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@map("ai_evaluations")
}

model PointRule {
  action      String   @id
  delta       Int
  label       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("point_rules")
}

model PointTransaction {
  id           String   @id @default(cuid())
  userId       String
  ideaId       String?
  action       String
  delta        Int
  balanceAfter Int
  reason       String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea         Idea?    @relation(fields: [ideaId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("point_transactions")
}

model IdeaUnlock {
  id        String   @id @default(cuid())
  userId    String
  ideaId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([userId, ideaId])
  @@map("idea_unlocks")
}
